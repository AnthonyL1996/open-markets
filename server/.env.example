# Open Markets backend — environment configuration (ALL optional; defaults shown).
# The service runs out of the box with no env set. Copy to `.env` and adjust for your deployment.
# docker compose reads this automatically; for `go run`/`make run`, export the vars or use a .env loader.

# ── Server ────────────────────────────────────────────────────────────────────
OM_ADDR=:8080                        # HTTP listen address
OM_VERSION=phase-a                   # version string reported by /health + in feeds
OM_READ_TIMEOUT_SEC=10               # per-request read timeout (seconds)
OM_WRITE_TIMEOUT_SEC=10              # per-request write timeout (seconds)

# ── Storage ──────────────────────────────────────────────────────────────────
OM_DATA=data/openmarkets.json        # JSON snapshot path (atomic writes). Mount a volume here in production.
OM_DB_URL=                           # empty → in-memory + JSON store; set a postgres:// URL → Postgres backend

# ── Market aggregation (MUST match the C# client) ──────────────────────────────
# The client and server must agree on these, or they disagree on how far reports move prices.
OM_VOLUME_REF=20000                  # net-supply scale reference
OM_INDEX_MIN=0.5                     # price index lower clamp
OM_INDEX_MAX=2.0                     # price index upper clamp

# ── Abuse limits ───────────────────────────────────────────────────────────────
OM_RATE_PER_MIN=120                  # per-IP requests/min. 0 disables. KEEP ON in production.
OM_ACCT_PER_HOUR=10                  # stricter limit on UNAUTHENTICATED account creation. 0 = unlimited (local only).
OM_TRUST_PROXY=0                     # 1 = trust X-Forwarded-For. Enable ONLY behind a trusted reverse proxy / tunnel.

# ── Operator console (/console) ────────────────────────────────────────────────
OM_CONSOLE=1                         # 1 = serve the operator web console. Set 0 in production.
OM_CONSOLE_TOKEN=                    # admin token for /console; empty leaves the local-dev console open (warned at startup)

# ── Due-clock (installment / austerity timing) ─────────────────────────────────
OM_DUE_INTERVAL_SEC=2700             # real seconds per installment period (≈ one in-game day at 1×). Lower for fast testing.
OM_DUE_GRACE=1                       # extra intervals before a due installment counts as missed
OM_DUE_MAX_MISSES_PER_TICK=4         # cap on missed installments processed per tick
OM_DUE_OFFLINE_GRACE=5               # extra periods an away player gets before auto-bonding
OM_DUE_OFFLINE_THRESHOLD_SEC=120     # last-seen age after which a player is treated as offline

# ── Background narrators / schedulers ──────────────────────────────────────────
OM_CHRONICLE_INTERVAL_SEC=60         # saga narrator: scans leagues for austerity/record-trade transitions (min 5s)
OM_CRISIS_INTERVAL_SEC=120           # shared league-crisis scheduler tick (min 10s)
OM_CRISIS_CHANCE=0.15                # per-interval probability of starting a new crisis (0..1)
OM_PROJECT_INTERVAL_SEC=300          # co-op Great Works generator: ensures each league has an open project (min 30s)

# ── Discord activity bridge (optional) ─────────────────────────────────────────
# Set a webhook to post NEW league activity (trades, bonds, investments, crises) to a Discord channel.
# Empty (default) keeps the bridge off. The poller seeds its cursor on boot — it never backfills history.
# OM_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
OM_DISCORD_INTERVAL_SEC=30           # how often the Discord poster polls for new events
